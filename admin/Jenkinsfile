pipeline {
    agent any

    environment {
        IMAGE_NAME = 'java-admin-service'
        IMAGE_TAG = "${BUILD_NUMBER}"  // auto increments each build
    }

    stages {

        stage('Checkout') {
            steps {
                echo '📥 Checking out code...'
                checkout scm
            }
        }

        stage('Test') {
            steps {
                echo '🧪 Running tests...'
                sh './gradlew test'
            }
        }

        stage('Build') {
            steps {
                echo '🔨 Building jar...'
                sh './gradlew bootJar -x test'
            }
        }

        stage('Docker Build') {
            steps {
                echo '🐳 Building Docker image...'
                sh """
                    podman build -t ${IMAGE_NAME}:${IMAGE_TAG} .
                    podman tag ${IMAGE_NAME}:${IMAGE_TAG} ${IMAGE_NAME}:latest
                """
            }
        }

        stage('Docker Push') {
            steps {
                echo '📦 Pushing to registry...'
                withCredentials([usernamePassword(
                    credentialsId: 'java-admin-credentials',
                    usernameVariable: 'USERNAME',
                    passwordVariable: 'PASSWORD'
                )]) {
                    sh """
                        podman login -u $USERNAME -p $PASSWORD docker.io
                        podman push ${IMAGE_NAME}:${IMAGE_TAG}
                        podman push ${IMAGE_NAME}:latest
                    """
                }
            }
        }

        stage('Deploy') {
            steps {
                echo '🚀 Deploying...'
                sh 'podman-compose up -d --build java-order-service'
            }
        }
    }

    post {
        success {
            echo '✅ Pipeline succeeded!'
        }
        failure {
            echo '❌ Pipeline failed!'
        }
        always {
            // clean up old images
            sh 'podman image prune -f'
        }
    }
}
